@model IEnumerable<FeedRSS.Models.Feed>

@{
    ViewData["Title"] = "Feeds";
}

<div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 mb-4">
    <div>
        <p class="text-uppercase small text-muted mb-1">Sources</p>
        <h1 class="mb-0">RSS Feeds</h1>
    </div>
    <a asp-action="Create" class="btn btn-primary">Add Feed</a>
</div>

<div class="table-responsive">
    <table class="table align-middle">
        <thead>
            <tr>
                <th>@Html.DisplayNameFor(model => model.Name)</th>
                <th>@Html.DisplayNameFor(model => model.Url)</th>
                <th>@Html.DisplayNameFor(model => model.LastReloadedAt)</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
@foreach (var item in Model)
{
            <tr>
                <td class="fw-semibold">@Html.DisplayFor(modelItem => item.Name)</td>
                <td><a href="@item.Url" target="_blank" rel="noreferrer noopener">@item.Url</a></td>
                <td>@(item.LastReloadedAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                <td class="text-end">
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
}
        </tbody>
    </table>
</div>
