@model FeedRSS.Models.Feed

@{
    ViewData["Title"] = "Feed Details";
}

<div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 mb-4">
    <div>
        <p class="text-uppercase small text-muted mb-1">Feed Detail</p>
        <h1 class="mb-0">@Model.Name</h1>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Edit</a>
        <a asp-action="Index" class="btn btn-outline-dark">Back</a>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="border rounded-4 p-3 h-100">
            <h4 class="h6 text-muted text-uppercase mb-3">Feed Info</h4>
            <dl class="mb-0">
                <dt>Name</dt>
                <dd class="mb-3">@Model.Name</dd>
                <dt>Url</dt>
                <dd class="mb-3"><a href="@Model.Url" target="_blank" rel="noreferrer noopener">@Model.Url</a></dd>
                <dt>Last Reloaded</dt>
                <dd class="mb-0">@(Model.LastReloadedAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</dd>
            </dl>
        </div>
    </div>
    <div class="col-lg-8">
        <div class="border rounded-4 p-3 h-100">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="h6 text-muted text-uppercase mb-0">Articles</h4>
                <span class="badge text-bg-light">@Model.Articles.Count item(s)</span>
            </div>
            @if (Model.Articles.Any())
            {
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Published</th>
                                <th>Link</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var article in Model.Articles.OrderByDescending(a => a.PublishedAt))
                        {
                            <tr>
                                <td>@article.Title</td>
                                <td>@(article.PublishedAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(article.Link))
                                    {
                                        <a href="@article.Link" target="_blank" rel="noreferrer noopener">Open</a>
                                    }
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted mb-0">No articles loaded for this feed yet.</p>
            }
        </div>
    </div>
</div>
