@model FeedRSS.ViewModels.FeedDetailsViewModel

@{
    ViewData["Title"] = "Feed Details";
}

<div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 mb-4">
    <div>
        <p class="text-uppercase small text-muted mb-1">Feed Detail</p>
        <h1 class="mb-0">@Model.Feed.Name</h1>
    </div>
    <div class="d-flex gap-2">
        <form asp-action="Reload" asp-route-id="@Model.Feed.Id" method="post" class="d-inline">
            <button type="submit" class="btn btn-primary">Reload Articles</button>
        </form>
        <a asp-action="Edit" asp-route-id="@Model.Feed.Id" class="btn btn-outline-secondary">Edit</a>
        <a asp-action="Index" class="btn btn-outline-dark">Back</a>
    </div>
</div>

@if (TempData["StatusMessage"] is string statusMessage)
{
    <div class="alert alert-info" role="alert">@statusMessage</div>
}

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-warning" role="alert" asp-validation-summary="ModelOnly"></div>
}

<div class="row g-4">
    <div class="col-lg-4">
        <div class="border rounded-4 p-3 h-100">
            <h4 class="h6 text-muted text-uppercase mb-3">Feed Info</h4>
            <dl class="mb-0">
                <dt>@Html.DisplayNameFor(model => model.Feed.Name)</dt>
                <dd class="mb-3">@Html.DisplayFor(model => model.Feed.Name)</dd>
                <dt>@Html.DisplayNameFor(model => model.Feed.Url)</dt>
                <dd class="mb-3"><a href="@Model.Feed.Url" target="_blank" rel="noreferrer noopener">@Model.Feed.Url</a></dd>
                <dt>@Html.DisplayNameFor(model => model.Feed.LastReloadedAt)</dt>
                <dd class="mb-0">@Html.DisplayFor(model => model.Feed.LastReloadedAt)</dd>
            </dl>
        </div>
    </div>
    <div class="col-lg-8">
        <div class="border rounded-4 p-3 h-100">
            <form asp-action="Details" method="get" class="row g-2 mb-3">
                <input type="hidden" name="id" value="@Model.Feed.Id" />
                <div class="col-12 col-md-4">
                    <label for="from" class="form-label mb-1">From</label>
                    <input type="date" id="from" name="from" value="@Model.From?.ToString("yyyy-MM-dd")" class="form-control" />
                </div>
                <div class="col-12 col-md-4">
                    <label for="to" class="form-label mb-1">To</label>
                    <input type="date" id="to" name="to" value="@Model.To?.ToString("yyyy-MM-dd")" class="form-control" />
                </div>
                <div class="col-12 col-md-4 d-flex align-items-end gap-2">
                    <button type="submit" class="btn btn-outline-primary">Apply</button>
                    <a asp-action="Details" asp-route-id="@Model.Feed.Id" class="btn btn-outline-secondary">Clear</a>
                </div>
            </form>

            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="h6 text-muted text-uppercase mb-0">Articles</h4>
                <span class="badge text-bg-light">@Model.Articles.Count item(s)</span>
            </div>
            @if (Model.Articles.Any())
            {
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                        <thead>
                            <tr>
                                <th>@Html.DisplayNameFor(model => model.Articles.First().Title)</th>
                                <th>@Html.DisplayNameFor(model => model.Articles.First().PublishedAt)</th>
                                <th>@Html.DisplayNameFor(model => model.Articles.First().Link)</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var article in Model.Articles)
                        {
                            <tr>
                                <td>@Html.DisplayFor(_ => article.Title)</td>
                                <td>@Html.DisplayFor(_ => article.PublishedAt)</td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(article.Link))
                                    {
                                        <a href="@article.Link" target="_blank" rel="noreferrer noopener">Open</a>
                                    }
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted mb-0">No articles loaded for this feed yet.</p>
            }
        </div>
    </div>
</div>
